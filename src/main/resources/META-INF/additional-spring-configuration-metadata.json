{
  "groups": [
    {
      "name": "supabase",
      "type": "com.techup.spring_demo.config.SupabaseProperties"
    },
    {
      "name": "jwt",
      "type": "com.techup.spring_demo.config.JwtProperties"
    },
    {
      "name": "app.cors",
      "type": "com.homeservice.homeservice_server.config.CorsProperties"
    }
  ],
  "properties": [
    {
      "name": "supabase.url",
      "type": "java.lang.String",
      "sourceType": "com.techup.spring_demo.config.SupabaseProperties",
      "description": "Supabase project URL."
    },
    {
      "name": "supabase.bucket",
      "type": "java.lang.String",
      "sourceType": "com.techup.spring_demo.config.SupabaseProperties",
      "description": "Supabase storage bucket name."
    },
    {
      "name": "supabase.api-key",
      "type": "java.lang.String",
      "sourceType": "com.techup.spring_demo.config.SupabaseProperties",
      "description": "Supabase API key used for storage access."
    },
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "sourceType": "com.techup.spring_demo.config.JwtProperties",
      "description": "Secret key used to sign JWT tokens."
    },
    {
      "name": "jwt.expiration",
      "type": "java.lang.Long",
      "sourceType": "com.techup.spring_demo.config.JwtProperties",
      "description": "JWT expiration time in milliseconds."
    },
    {
      "name": "app.cors.allowed-origins",
      "type": "java.lang.String",
      "sourceType": "com.homeservice.homeservice_server.config.CorsProperties",
      "description": "Comma-separated list of allowed browser origins for CORS (e.g. Vue dev server and production frontend URLs)."
    }
  ]
}
